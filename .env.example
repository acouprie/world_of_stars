# Copier en .env (ignoré par git) et remplir les valeurs

# Base de données
DATABASE_URL=postgresql://postgres:password@localhost:5432/world_of_stars_development
DB_HOST=localhost
DB_USER=postgres
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_MASTER_KEY=  # contenu de config/master.key

# Déploiement (Kamal)
DEPLOY_SERVER_IP=
KAMAL_REGISTRY_PASSWORD=

GID=1000
UID=1000