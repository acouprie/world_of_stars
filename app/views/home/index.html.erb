<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>
<h1>World of Stars</h1>

<% if authenticated? %>
  <p>Connecté en tant que <%= Current.session.user.email_address %></p>
  <%= button_to "Se déconnecter", session_path, method: :delete %>
<% else %>

  <%= form_with url: session_path do |form| %>
    <%= form.email_field :email_address, required: true, autofocus: true,
        autocomplete: "username", placeholder: "Adresse e-mail",
        value: params[:email_address] %><br>
    <%= form.password_field :password, required: true,
        autocomplete: "current-password", placeholder: "Mot de passe", maxlength: 72 %><br>
    <%= form.submit "Se connecter" %>
  <% end %>

  <%= link_to "Mot de passe oublié ?", new_password_path %>
<% end %>
