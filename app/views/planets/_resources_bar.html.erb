<% planet = local_assigns.fetch(:planet, @planet) %>
<div id="resources_bar" class="sticky top-0 z-50 border-b border-border bg-space-bg-2/95 backdrop-blur-sm"
  data-controller="resources"
  data-resources-updated-at-value="<%= planet.resources_updated_at.iso8601(3) %>"
  data-resources-food-stock-value="<%= planet.food_stock %>"
  data-resources-food-rate-value="<%= planet.food_rate %>"
  data-resources-food-capacity-value="<%= planet.food_capacity %>"
  data-resources-metal-stock-value="<%= planet.metal_stock %>"
  data-resources-metal-rate-value="<%= planet.metal_rate %>"
  data-resources-metal-capacity-value="<%= planet.metal_capacity %>"
  data-resources-thorium-stock-value="<%= planet.thorium_stock %>"
  data-resources-thorium-rate-value="<%= planet.thorium_rate %>"
  data-resources-thorium-capacity-value="<%= planet.thorium_capacity %>">
  <div class="mx-auto grid grid-cols-2 gap-5 p-5 sm:flex sm:items-center sm:px-4 sm:py-2 sm:text-sm scifi-text">

    <%
      energy_pct = planet.total_energy_produced > 0 ?
        [(planet.total_energy_consumed.to_f / planet.total_energy_produced * 100).round, 100].min : 0
      energy_bar_color = energy_pct > 90 ? "bg-red-400" : energy_pct > 70 ? "bg-amber-400" : "bg-primary"
      energy_value_class = planet.total_energy_consumed > planet.total_energy_produced ? "text-red-400" : "text-primary"
    %>
    <div class="flex items-center gap-2 rounded-md border border-border bg-surface px-2 py-1.5 sm:flex-1 sm:px-3">
      <%= image_tag "icons/energy.png", alt: t("resources.energy"), class: "h-4 w-4 shrink-0" %>
      <div class="flex min-w-0 flex-1 flex-col gap-1">
        <div class="flex items-center justify-between gap-1">
          <span class="text-xs font-medium uppercase tracking-wider text-text-muted"><%= t("resources.energy") %></span>
          <span class="font-mono text-xs text-text">
            <span class="<%= energy_value_class %>"><%= planet.total_energy_consumed %></span>
            <span class="text-text-subtle">/</span>
            <%= planet.total_energy_produced %> GWh
          </span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-border">
          <div class="h-full rounded-full transition-all duration-500 <%= energy_bar_color %>" style="width: <%= energy_pct %>%"></div>
        </div>
      </div>
    </div>

    <% food_pct = planet.food_capacity > 0 ? [(planet.food_stock.to_f / planet.food_capacity * 100).round, 100].min : 0 %>
    <div class="flex items-center gap-2 rounded-md border border-border bg-surface px-2 py-1.5 sm:flex-1 sm:px-3">
      <%= image_tag "icons/food.png", alt: t("resources.food"), class: "h-4 w-4 shrink-0" %>
      <div class="flex min-w-0 flex-1 flex-col gap-1">
        <div class="flex items-center justify-between gap-1">
          <div class="flex flex-row gap-1">
            <span class="text-xs font-medium uppercase tracking-wider text-text-muted"><%= t("resources.food") %></span>
            <span class="text-[10px] text-text-subtle">+<%= number_with_delimiter((planet.food_rate * 3600).to_i) %> /h</span>
          </div>
          <span class="font-mono text-xs text-text">
            <span class="text-secondary" data-resources-target="foodStock"><%= number_with_delimiter(planet.food_stock.to_i) %></span>
            <span class="text-text-subtle">/</span>
            <%= number_with_delimiter(planet.food_capacity) %>
          </span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-border">
          <div class="h-full rounded-full bg-secondary transition-all duration-500 <%= food_pct >= 100 ? 'opacity-50' : '' %>" style="width: <%= food_pct %>%" data-resources-target="foodBar"></div>
        </div>
      </div>
    </div>

    <% metal_pct = planet.metal_capacity > 0 ? [(planet.metal_stock.to_f / planet.metal_capacity * 100).round, 100].min : 0 %>
    <div class="flex items-center gap-2 rounded-md border border-border bg-surface px-2 py-1.5 sm:flex-1 sm:px-3">
      <%= image_tag "icons/metal.png", alt: t("resources.metal"), class: "h-4 w-4 shrink-0" %>
      <div class="flex min-w-0 flex-1 flex-col gap-1">
        <div class="flex items-center justify-between gap-1">
          <div class="flex flex-row gap-1">
            <span class="text-xs font-medium uppercase tracking-wider text-text-muted"><%= t("resources.metal") %></span>
            <span class="text-[10px] text-text-subtle">+<%= number_with_delimiter((planet.metal_rate * 3600).to_i) %> /h</span>
          </div>
          <span class="font-mono text-xs text-text">
            <span class="text-secondary" data-resources-target="metalStock"><%= number_with_delimiter(planet.metal_stock.to_i) %></span>
            <span class="text-text-subtle">/</span>
            <%= number_with_delimiter(planet.metal_capacity) %>
          </span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-border">
          <div class="h-full rounded-full bg-secondary transition-all duration-500 <%= metal_pct >= 100 ? 'opacity-50' : '' %>" style="width: <%= metal_pct %>%" data-resources-target="metalBar"></div>
        </div>
      </div>
    </div>

    <% thorium_pct = planet.thorium_capacity > 0 ? [(planet.thorium_stock.to_f / planet.thorium_capacity * 100).round, 100].min : 0 %>
    <div class="flex items-center gap-2 rounded-md border border-border bg-surface px-2 py-1.5 sm:flex-1 sm:px-3">
      <%= image_tag "icons/thorium.png", alt: t("resources.thorium"), class: "h-4 w-4 shrink-0" %>
      <div class="flex min-w-0 flex-1 flex-col gap-1">
        <div class="flex items-center justify-between gap-1">
          <div class="flex flex-row gap-1">
            <span class="text-xs font-medium uppercase tracking-wider text-text-muted"><%= t("resources.thorium") %></span>
            <span class="text-[10px] text-text-subtle">+<%= number_with_delimiter((planet.thorium_rate * 3600).to_i) %> /h</span>
          </div>
          <span class="font-mono text-xs text-text">
            <span class="text-quantum" data-resources-target="thoriumStock"><%= number_with_delimiter(planet.thorium_stock.to_i) %></span>
            <span class="text-text-subtle">/</span>
            <%= number_with_delimiter(planet.thorium_capacity) %>
          </span>
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-border">
          <div class="h-full rounded-full bg-quantum transition-all duration-500 <%= thorium_pct >= 100 ? 'opacity-50' : '' %>" style="width: <%= thorium_pct %>%" data-resources-target="thoriumBar"></div>
        </div>
      </div>
    </div>

  </div>
</div>
