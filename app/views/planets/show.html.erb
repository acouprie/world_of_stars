<% provide(:title, "World of Stars - " + @planet.name) %>
<%= turbo_stream_from "planet_#{@planet.id}" %>

<%= render 'planets/resources_bar', planet: @planet %>

<div class="scifi-text flex px-5 p-8">
  <div class="flex flex-col gap-1">
    <div>
    <%= @planet.name %>
    <% if @planet.is_home %>
      <span class="inline-flex items-center rounded-md bg-blue-950 px-2 py-1 text-xs font-medium text-blue-500 inset-ring inset-ring-blue-700/10"><%= t("planets.show.home_badge") %></span>
    <% end %>
    </div>
    <span>[ <%= @planet.coord_x %> : <%= @planet.coord_y %> ]
  </div>
</div>

<%= render 'planets/canvas_container', planet: @planet %>

<%= render "construction_queues/queue_bar", planet: @planet %>

<%= render "training_queues/queues_bar", planet: @planet %>

<div id="buildings-list-container">
  <%= render 'planets/buildings_list', planet: @planet %>
</div>

<div class="px-5 pb-2">
  <%= link_to t("training_queues.manage_link"), planet_training_queues_path(@planet),
        class: "scifi-text text-[11px] text-military hover:text-military/70 transition-colors" %>
</div>
