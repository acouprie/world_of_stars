<dialog data-confirm-dialog-target="dialog"
        data-action="click->confirm-dialog#clickOutside"
        class="confirm-dialog">
  <div class="confirm-dialog__inner">
    <h2 class="confirm-dialog__title" data-confirm-dialog-target="title"></h2>
    <p class="confirm-dialog__message" data-confirm-dialog-target="message"></p>
    <div class="confirm-dialog__actions">
      <button type="button"
              class="confirm-dialog__btn confirm-dialog__btn--secondary"
              data-action="click->confirm-dialog#cancel">
        <%= t("ui.cancel") %>
      </button>
      <%= form_with url: "#", method: :delete,
                    data: { "confirm-dialog-target": "form" } do %>
        <button type="button"
                class="confirm-dialog__btn confirm-dialog__btn--danger"
                data-action="click->confirm-dialog#confirm">
          <%= t("ui.confirm") %>
        </button>
      <% end %>
    </div>
  </div>
</dialog>
