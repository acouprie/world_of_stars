<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title><%= [content_for(:title), "World of Stars"].compact.join(" — ") %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --space-bg:    #0d0e12;
      --surface:     #1c1d27;
      --border:      #2a2b38;
      --text:        #e8e4d8;
      --text-muted:  #a09e96;
      --text-subtle: #5e5d58;
      --gold:        #c8a96e;
      --blue:        #4e8faf;
      --cyan:        #2ec4a0;
      --red:         #e8622a;
    }

    html, body {
      height: 100%;
      background: var(--space-bg);
      color: var(--text);
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
      overflow: hidden;
    }

    /* ─── STARFIELD ─── */
    .starfield {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }
    .starfield::before {
      content: '';
      position: absolute;
      inset: -150px;
      background-image:
        radial-gradient(1px 1px at  8% 12%, rgba(232,228,216,.8) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 15% 42%, rgba(200,169,110,.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 22% 75%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 28% 28%, rgba(232,228,216,.6) 0%, transparent 100%),
        radial-gradient(2px 2px at 35% 58%, rgba(78,143,175,.35) 0%, transparent 100%),
        radial-gradient(1px 1px at 42% 85%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 48% 18%, rgba(200,169,110,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 55% 68%, rgba(232,228,216,.7) 0%, transparent 100%),
        radial-gradient(1px 1px at 62% 35%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 68% 92%, rgba(46,196,160,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 75% 22%, rgba(232,228,216,.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 82% 55%, rgba(200,169,110,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 88% 78%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(2px 2px at 93% 12%, rgba(78,143,175,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at  5% 88%, rgba(232,228,216,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 12% 62%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 20%  8%, rgba(200,169,110,.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 30% 48%, rgba(232,228,216,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 40% 72%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 50% 32%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 58% 88%, rgba(46,196,160,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 65% 52%, rgba(232,228,216,.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 72%  8%, rgba(232,228,216,.3) 0%, transparent 100%),
        radial-gradient(2px 2px at 78% 42%, rgba(200,169,110,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 85% 68%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 92% 35%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at  3% 35%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 45%  5%, rgba(78,143,175,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 78%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 96% 58%, rgba(200,169,110,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 17% 95%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 53% 15%, rgba(46,196,160,.25) 0%, transparent 100%),
        radial-gradient(1px 1px at 87% 32%, rgba(232,228,216,.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 33% 82%, rgba(200,169,110,.2) 0%, transparent 100%),
        radial-gradient(1px 1px at 60% 10%, rgba(232,228,216,.6) 0%, transparent 100%),
        radial-gradient(2px 2px at  7% 55%, rgba(78,143,175,.25) 0%, transparent 100%),
        radial-gradient(1px 1px at 25% 20%, rgba(232,228,216,.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 80%  5%, rgba(232,228,216,.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 38% 38%, rgba(232,228,216,.3) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 98% 85%, rgba(200,169,110,.4) 0%, transparent 100%);
      animation: stars-drift 200s linear infinite;
    }
    @keyframes stars-drift {
      0%   { transform: translate(0, 0); }
      100% { transform: translate(150px, 150px); }
    }

    /* ─── SCANLINES ─── */
    .scanlines {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0,0,0,.018) 3px,
        rgba(0,0,0,.018) 4px
      );
    }

    /* ─── PAGE ─── */
    .error-page {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    /* ─── CARD ─── */
    .error-card {
      width: min(100%, 580px);
      background: rgba(28,29,39,.78);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      padding: 2.25rem 2.5rem;
      text-align: center;
      position: relative;
    }
    .error-card::before,
    .error-card::after {
      content: '';
      position: absolute;
      width: 18px;
      height: 18px;
      border-style: solid;
      border-color: var(--gold);
    }
    .error-card::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
    .error-card::after  { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

    /* ─── STATUS BAR ─── */
    .status-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: .6rem;
      letter-spacing: .12em;
      color: var(--text-subtle);
    }
    .status-indicator { display: flex; align-items: center; gap: .45rem; }
    .status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      animation: blink 1.4s ease-in-out infinite;
    }
    .status-dot.red  { background: var(--red); }
    .status-dot.gold { background: var(--gold); }
    .status-dot.blue { background: var(--blue); }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: .15; }
    }

    /* ─── ERROR CODE ─── */
    .error-code {
      font-size: clamp(5rem, 22vw, 9.5rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -.02em;
      margin-bottom: 1.25rem;
      animation: glitch 12s ease-in-out infinite;
    }
    .error-code.gold {
      color: var(--gold);
      text-shadow: 0 0 40px rgba(200,169,110,.4), 0 0 90px rgba(200,169,110,.15);
      animation: glow-gold 3.5s ease-in-out infinite, glitch 12s ease-in-out infinite;
    }
    .error-code.red {
      color: var(--red);
      text-shadow: 0 0 40px rgba(232,98,42,.4), 0 0 90px rgba(232,98,42,.15);
      animation: glow-red 3.5s ease-in-out infinite, glitch 12s ease-in-out infinite;
    }
    .error-code.blue {
      color: var(--blue);
      text-shadow: 0 0 40px rgba(78,143,175,.4), 0 0 90px rgba(78,143,175,.15);
      animation: glow-blue 3.5s ease-in-out infinite, glitch 12s ease-in-out infinite;
    }
    @keyframes glow-gold {
      0%,100% { text-shadow: 0 0 40px rgba(200,169,110,.4), 0 0 90px rgba(200,169,110,.15); }
      50%      { text-shadow: 0 0 55px rgba(200,169,110,.6), 0 0 110px rgba(200,169,110,.25); }
    }
    @keyframes glow-red {
      0%,100% { text-shadow: 0 0 40px rgba(232,98,42,.4), 0 0 90px rgba(232,98,42,.15); }
      50%      { text-shadow: 0 0 55px rgba(232,98,42,.6), 0 0 110px rgba(232,98,42,.25); }
    }
    @keyframes glow-blue {
      0%,100% { text-shadow: 0 0 40px rgba(78,143,175,.4), 0 0 90px rgba(78,143,175,.15); }
      50%      { text-shadow: 0 0 55px rgba(78,143,175,.6), 0 0 110px rgba(78,143,175,.25); }
    }
    @keyframes glitch {
      0%,87%,100% { transform: translate(0); }
      88% { transform: translate(-3px, 1px); filter: hue-rotate(12deg) brightness(1.08); }
      89% { transform: translate(3px,-1px); filter: hue-rotate(-12deg); }
      90% { transform: translate(-1px,0); }
      91% { transform: translate(0); filter: none; }
    }

    /* ─── HEADINGS ─── */
    .error-heading {
      font-size: clamp(.85rem, 3vw, 1.05rem);
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: .3rem;
    }
    .error-subtitle {
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: .7rem;
      letter-spacing: .08em;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    /* ─── DIVIDER ─── */
    .divider {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin: 1.5rem 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .divider-glyph {
      color: var(--gold);
      opacity: .5;
      font-size: .75rem;
      letter-spacing: .15em;
    }

    /* ─── MESSAGE ─── */
    .error-message {
      font-size: .875rem;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    /* ─── DATA READOUT ─── */
    .data-readout {
      background: rgba(13,14,18,.65);
      border: 1px solid var(--border);
      padding: .875rem 1.125rem;
      margin-bottom: 2rem;
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: .62rem;
      letter-spacing: .09em;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: .3rem 1.25rem;
      text-align: left;
    }
    .data-readout .k { color: var(--text-subtle); }
    .data-readout .v-err  { color: var(--red); }
    .data-readout .v-warn { color: var(--gold); }
    .data-readout .v-ok   { color: var(--cyan); }
    .data-readout .v-info { color: var(--blue); }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .7rem 1.6rem;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid;
      transition: background .2s, box-shadow .2s;
      cursor: pointer;
      background: none;
      font-family: inherit;
    }
    .btn-gold {
      border-color: rgba(200,169,110,.5);
      color: var(--gold);
    }
    .btn-gold:hover {
      background: rgba(200,169,110,.1);
      box-shadow: 0 0 22px rgba(200,169,110,.2);
    }
    .btn-blue {
      border-color: rgba(78,143,175,.5);
      color: var(--blue);
    }
    .btn-blue:hover {
      background: rgba(78,143,175,.1);
      box-shadow: 0 0 22px rgba(78,143,175,.2);
    }
    .btn-red {
      border-color: rgba(232,98,42,.5);
      color: var(--red);
    }
    .btn-red:hover {
      background: rgba(232,98,42,.1);
      box-shadow: 0 0 22px rgba(232,98,42,.2);
    }
    .btn-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    @media (max-width: 480px) {
      .error-card { padding: 1.75rem 1.25rem; }
      .status-bar { flex-direction: column; align-items: flex-start; gap: .3rem; }
    }
  </style>
</head>
<body>
  <div class="starfield" aria-hidden="true"></div>
  <div class="scanlines" aria-hidden="true"></div>
  <div class="error-page">
    <%= yield %>
  </div>
</body>
</html>
