<%
  locale_flags = { 'fr' => '🇫🇷', 'en' => '🇬🇧' }
  current_locale = I18n.locale.to_s
%>
<header class="top-0 left-0 right-0 z-50 flex items-center justify-between sm:justify-end gap-2 p-2">

  <%# Mobile hamburger menu (hidden on sm+) %>
  <div class="relative sm:hidden"
       data-controller="nav-menu"
       data-action="click@window->nav-menu#closeOnOutside">
    <button type="button"
            class="cursor-pointer p-2 rounded hover:bg-white/10 select-none text-xl"
            style="color: var(--color-primary)"
            data-action="click->nav-menu#toggle">☰</button>
    <div id="mobile-nav-menu" data-nav-menu-target="menu">
      <%= link_to docs_path,
          class: "block px-4 py-2.5 text-sm font-medium hover:bg-white/10 transition-colors",
          style: "color: var(--color-primary)" do %>
        <%= t("layouts.header.documentation") %>
      <% end %>
      <% if authenticated? %>
        <%= link_to galaxy_path,
            class: "block px-4 py-2.5 text-sm font-medium hover:bg-white/10 transition-colors",
            style: "color: var(--color-primary)" do %>
          <%= t("layouts.header.galaxy") %>
        <% end %>
        <%= link_to planet_path(Current.user.planets.first),
            class: "block px-4 py-2.5 text-sm font-medium hover:bg-white/10 transition-colors",
            style: "color: var(--color-primary)" do %>
          <%= t("layouts.header.home_planet") %>
        <% end %>
        <%= button_to session_path, method: :delete,
            class: "flex items-center gap-2 px-4 py-2.5 w-full text-sm font-medium hover:bg-white/10 transition-colors cursor-pointer",
            style: "color: var(--color-primary)" do %>
          <span>⏻</span>
          <span><%= t("home.index.logout") %></span>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Desktop navigation (hidden on mobile) %>
  <div class="hidden sm:flex items-center gap-2">
    <%= link_to docs_path,
        class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-white/10 transition-colors",
        style: "color: var(--color-primary)" do %>
      <%= t("layouts.header.documentation") %>
    <% end %>
    <% if authenticated? %>
      <%= link_to galaxy_path,
          class: "block px-4 py-2.5 text-sm font-medium hover:bg-white/10 transition-colors",
          style: "color: var(--color-primary)" do %>
        <%= t("layouts.header.galaxy") %>
      <% end %>
      <%= link_to planet_path(Current.user.planets.first),
          class: "px-3 py-1.5 rounded text-sm font-medium hover:bg-white/10 transition-colors",
          style: "color: var(--color-primary)" do %>
        <%= t("layouts.header.home_planet") %>
      <% end %>
      <%= button_to session_path, method: :delete,
          class: "flex items-center gap-2 px-3 py-1.5 rounded text-sm font-medium hover:bg-white/10 transition-colors cursor-pointer",
          style: "color: var(--color-primary)" do %>
        <span>⏻</span>
        <span><%= t("home.index.logout") %></span>
      <% end %>
    <% end %>
  </div>

  <%# Language switcher (always visible) %>
  <details class="relative inline-block">
    <summary class="cursor-pointer list-none text-2xl p-2 rounded hover:bg-white/10 select-none">
      <%= locale_flags[current_locale] %>
    </summary>
    <div class="absolute right-0 mt-1 rounded border border-white/20 shadow-xl z-100 min-w-max overflow-hidden"
         style="background-color: var(--color-space-bg)">
      <% locale_flags.keys.each do |locale| %>
        <%= button_to update_locale_path, params: { locale: locale },
            class: "flex items-center gap-3 px-4 py-2 w-full hover:bg-white/10 transition-colors cursor-pointer#{' bg-white/5' if locale == current_locale}",
            style: "color: var(--color-primary)" do %>
          <span><%= locale_flags[locale] %></span>
          <span class="text-sm font-medium"><%= t("locale_switcher.#{locale}") %></span>
        <% end %>
      <% end %>
    </div>
  </details>

</header>
