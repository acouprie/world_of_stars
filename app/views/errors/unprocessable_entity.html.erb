<% content_for :title, t("errors.unprocessable.title") %>

<div class="error-card">
  <div class="status-bar">
    <div class="status-indicator">
      <span class="status-dot gold"></span>
      COMM_RELAY — PACKET_CORRUPTED
    </div>
    <div><%= t("errors.game_label") %></div>
  </div>

  <div class="error-code gold">422</div>

  <h1 class="error-heading"><%= t("errors.unprocessable.heading") %></h1>
  <p class="error-subtitle"><%= t("errors.unprocessable.subtitle") %></p>

  <div class="divider">
    <span class="divider-glyph">◈</span>
  </div>

  <p class="error-message"><%= t("errors.unprocessable.message") %></p>

  <div class="data-readout" aria-hidden="true">
    <span class="k">SIGNAL</span>   <span class="v-err">CORRUPTED</span>
    <span class="k">PACKET</span>   <span class="v-err">UNPROCESSABLE</span>
    <span class="k">CAUSE</span>    <span class="v-warn">UNKNOWN</span>
    <span class="k">ACTION</span>   <span class="v-info">RETRANSMIT</span>
  </div>

  <div class="btn-actions">
    <a href="/" class="btn btn-gold">← <%= t("errors.unprocessable.back") %></a>
  </div>
</div>
