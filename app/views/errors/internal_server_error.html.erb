<% content_for :title, t("errors.internal.title") %>

<div class="error-card">
  <div class="status-bar">
    <div class="status-indicator">
      <span class="status-dot red"></span>
      CMD_CENTER — CRITICAL_FAILURE
    </div>
    <div><%= t("errors.game_label") %></div>
  </div>

  <div class="error-code red">500</div>

  <h1 class="error-heading"><%= t("errors.internal.heading") %></h1>
  <p class="error-subtitle"><%= t("errors.internal.subtitle") %></p>

  <div class="divider">
    <span class="divider-glyph">◈</span>
  </div>

  <p class="error-message"><%= t("errors.internal.message") %></p>

  <div class="data-readout" aria-hidden="true">
    <span class="k">REACTOR</span>  <span class="v-err">CRITICAL</span>
    <span class="k">TEAM</span>     <span class="v-ok">ELYRANS_ETA: ???</span>
    <span class="k">CAUSE</span>    <span class="v-warn">UNKNOWN</span>
    <span class="k">STATUS</span>   <span class="v-err">OFFLINE</span>
  </div>

  <div class="btn-actions">
    <button onclick="location.reload()" class="btn btn-red">⟳ <%= t("errors.internal.retry") %></button>
    <a href="/" class="btn btn-blue">← <%= t("errors.internal.home") %></a>
  </div>
</div>
